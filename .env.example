# shellcheck disable=all
# ── Database (required) ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# ── NextAuth (required) ──────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="openssl rand -base64 32"

# ── Resend — Email (recommended) ─────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Shiftfy <noreply@shiftfy.de>"

# ── Stripe — Billing (recommended) ───────────────────────────────
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_TEAM_MONTHLY=""
STRIPE_PRICE_TEAM_ANNUAL=""
STRIPE_PRICE_BUSINESS_MONTHLY=""
STRIPE_PRICE_BUSINESS_ANNUAL=""

# ── OAuth — Google (optional) ────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── OAuth — Azure AD (optional) ──────────────────────────────────
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"

# ── Web Push — VAPID (optional) ──────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@shiftfy.de"

# ── Sentry — Error Tracking (REQUIRED for production) ────────────
# Without this, error monitoring is completely disabled and you're flying blind.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ── Cron — Vercel Cron Jobs (optional) ───────────────────────────
CRON_SECRET="openssl rand -base64 32"

# Stripe simulation mode — set to "true" to bypass Stripe and simulate billing in-database
STRIPE_SIMULATION_MODE=false
