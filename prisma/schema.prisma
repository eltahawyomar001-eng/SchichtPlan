generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String                   @unique
  phone                   String?
  emailVerified           DateTime?
  hashedPassword          String?
  image                   String?
  role                    Role                     @default(OWNER)
  consentGivenAt          DateTime?
  twoFactorEnabled        Boolean                  @default(false)
  twoFactorSecret         String?
  twoFactorRecoveryCodes  String?
  dashboardFavorites      String                   @default("[]") @db.Text
  preferredLocale         String                   @default("de")
  // GDPR/legal: track which AGB/Datenschutz version the user accepted and when
  tosVersion              String?
  tosAcceptedAt           DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  workspaceId             String?
  workspace               Workspace?               @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  customRoleId            String?
  customRole              CustomRole?              @relation("UserCustomRole", fields: [customRoleId], references: [id], onDelete: SetNull)
  accounts                Account[]
  sessions                Session[]
  notificationPreferences NotificationPreference[]
  invitationsSent         Invitation[]
  employee                Employee?
  pushSubscriptions       PushSubscription[]
  autoScheduleRuns        AutoScheduleRun[]
  icalTokens              ICalToken[]
  notifications           Notification[]
  ticketsCreated          Ticket[]                 @relation("TicketCreator")
  ticketsAssigned         Ticket[]                 @relation("TicketAssignee")
  ticketsTrashed          Ticket[]                 @relation("TicketTrasher")
  ticketComments          TicketComment[]
  ticketAttachments       TicketAttachment[]
  feedback                Feedback[]
  userTasks               UserTask[]
  sosRequestsCreated      SosRequest[]             @relation("SosCreatedBy")
  betriebsratMembership   BetriebsratMember?
  approvalsSubmitted      ShiftPlanApproval[]      @relation("ApprovalSubmitter")
  approvalsReviewed       ShiftPlanApproval[]      @relation("ApprovalReviewer")
}

/// Personal to-do list shown on the dashboard "My Tasks" card.
/// Scoped to a single user; deleted when the user is removed.
model UserTask {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  title       String
  done        Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  /// When this OAuth provider was linked to the account. Used for security
  /// auditing — lets admins detect when a credentials account had an OAuth
  /// provider attached, and whether it was done deliberately.
  linkedAt          DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id          String           @id @default(cuid())
  token       String           @unique
  email       String
  role        Role             @default(EMPLOYEE)
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User             @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email, workspaceId])
}

model Workspace {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  industry             String?
  bundesland           String?
  /// Default/target break duration in minutes shown as countdown on the punch clock.
  /// German default per ArbZG §4: 30 min for 6–9h shifts, 45 min for >9h shifts.
  defaultBreakMinutes  Int                   @default(30)
  onboardingCompleted  Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  members              User[]
  employees            Employee[]
  shifts               Shift[]
  locations            Location[]
  departments          Department[]
  timeEntries          TimeEntry[]
  absenceRequests      AbsenceRequest[]
  availabilities       Availability[]
  shiftSwaps           ShiftSwapRequest[]
  shiftChangeRequests  ShiftChangeRequest[]
  timeAccounts         TimeAccount[]
  automationSettings   AutomationSetting[]
  invitations          Invitation[]
  vacationBalances     VacationBalance[]
  skills               Skill[]
  shiftTemplates       ShiftTemplate[]
  clients              Client[]
  projects             Project[]
  monthCloses          MonthClose[]
  exportJobs           ExportJob[]
  webhookEndpoints     WebhookEndpoint[]
  webhookFailures      WebhookFailure[]
  automationRules      AutomationRule[]
  auditLogs            AuditLog[]
  eSignatures          ESignature[]
  subscription         Subscription?
  usage                WorkspaceUsage?
  staffingRequirements StaffingRequirement[]
  autoScheduleRuns     AutoScheduleRun[]
  autoFillLogs         AutoFillLog[]
  managerAlerts        ManagerAlert[]
  serviceVisits        ServiceVisit[]
  serviceReports       ServiceReport[]
  notifications        Notification[]
  tickets              Ticket[]
  ticketAttachments    TicketAttachment[]
  ticketCategoryDefs   TicketCategoryDef[]
  workspaceCustomer    WorkspaceCustomer?
  invoices             Invoice[]
  feedback             Feedback[]
  invoiceSequence      InvoiceSequence?
  stationSessions      StationSession[]
  customRoles          CustomRole[]
  userTasks            UserTask[]
  sosRequests          SosRequest[]
  betriebsratMembers   BetriebsratMember[]
  shiftPlanApprovals   ShiftPlanApproval[]
}

// ═══════════════════════════════════════════════════════════════
// BETRIEBSRAT (WORKS COUNCIL) CO-DETERMINATION — BetrVG §87
// ═══════════════════════════════════════════════════════════════

/// A works-council member designated by the employer. Members can review and
/// approve/object to submitted shift schedules via the Betriebsrat portal.
model BetriebsratMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /// The User account that acts as the works-council member.
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Works-council chair (Vorsitzende:r) — informational.
  isChair     Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

enum ShiftPlanApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

/// A shift schedule (period + optional location scope) submitted to the works
/// council for co-determination per BetrVG §87. Tracks a response deadline.
model ShiftPlanApproval {
  id           String                  @id @default(cuid())
  workspaceId  String
  workspace    Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title        String
  periodStart  DateTime                @db.Date
  periodEnd    DateTime                @db.Date
  locationId   String?
  /// Snapshot of the schedule scope at submission (shift/employee counts).
  shiftCount   Int                     @default(0)
  status       ShiftPlanApprovalStatus @default(PENDING)
  /// Statutory response deadline (default: submittedAt + 3 days).
  deadline     DateTime
  decisionNote String?                 @db.Text
  submittedById String
  submittedBy   User                   @relation("ApprovalSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  reviewedById String?
  reviewedBy   User?                   @relation("ApprovalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([workspaceId, status])
  @@index([workspaceId, periodStart])
}

/// Custom roles (Business+ feature). Each role inherits from a baseRole
/// (OWNER/ADMIN/MANAGER/EMPLOYEE) and overrides individual permissions.
/// A permission entry looks like "shifts.create", "employees.read", or "shifts.*".
model CustomRole {
  id            String    @id @default(cuid())
  workspaceId   String
  name          String
  nameEn        String?
  description   String?
  descriptionEn String?
  /// One of OWNER, ADMIN, MANAGER, EMPLOYEE — sets the default permission floor.
  baseRole      String    @default("EMPLOYEE")
  /// JSON array of permission strings, e.g. ["shifts.*", "employees.read"]
  permissions   Json      @default("[]")
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  users         User[]    @relation("UserCustomRole")

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

/// In-app bug reports / feature requests submitted via the dashboard widget.
model Feedback {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  /// "BUG" | "FEATURE" | "QUESTION" | "OTHER"
  category    String
  subject     String
  message     String    @db.Text
  url         String?
  userAgent   String?
  /// "OPEN" | "TRIAGED" | "RESOLVED"
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status, createdAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════
// STRIPE BILLING & SUBSCRIPTIONS
// ═══════════════════════════════════════════════════════════════

enum SubscriptionPlan {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

enum ContractType {
  VOLLZEIT
  TEILZEIT
  MINIJOB
  MIDIJOB
}

/// Ticketing add-on tiers. NONE = add-on not purchased.
/// Limits enforced via WorkspaceUsage (tickets/month + storage bytes).
enum TicketingAddonTier {
  NONE
  STARTER
  GROWTH
  BUSINESS
}

model Subscription {
  id                                     String             @id @default(cuid())
  plan                                   SubscriptionPlan   @default(BASIC)
  status                                 SubscriptionStatus @default(ACTIVE)
  stripeCustomerId                       String?            @unique
  stripeSubscriptionId                   String?            @unique
  stripePriceId                          String?
  seatCount                              Int                @default(1)
  currentPeriodStart                     DateTime?
  currentPeriodEnd                       DateTime?
  cancelAtPeriodEnd                      Boolean            @default(false)
  trialStart                             DateTime?
  trialEnd                               DateTime?
  /// Ticketing add-on tier (NONE = not purchased)
  ticketingTier                          TicketingAddonTier @default(NONE)
  /// Stripe Subscription Item ID for the ticketing add-on line on the parent subscription
  ticketingStripeSubscriptionItemId      String?
  /// Schichtplanung add-on active flag (gates the entire shift planning module on Basic/Professional plans).
  /// Enterprise plan always has access regardless of this flag.
  schichtplanungAddonActive              Boolean            @default(false)
  /// Stripe Subscription Item ID for the schichtplanung add-on line on the parent subscription
  schichtplanungStripeSubscriptionItemId String?
  /// Billing cycle for the schichtplanung add-on: "monthly" or "annual" (null when inactive)
  schichtplanungAddonBilling             String?
  /// Set when seat count exceeds plan limit; hard-block activates 30 days after this date.
  overLimitSince                         DateTime?
  createdAt                              DateTime           @default(now())
  updatedAt                              DateTime           @updatedAt
  workspaceId                            String             @unique
  workspace                              Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

/// Company-level billing identity — VAT ID, billing address, and contact email
/// decoupled from any individual user. Multiple admins can manage billing.
model WorkspaceCustomer {
  id                String    @id @default(cuid())
  workspaceId       String    @unique
  companyName       String?
  vatId             String?
  billingEmail      String?
  billingAddress    String?
  billingCity       String?
  billingPostalCode String?
  billingCountry    String    @default("DE")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

/// GoBD § 147 — invoices must be retained for 10 years.
/// Populated by the invoice.paid Stripe webhook.
model Invoice {
  id               String    @id @default(cuid())
  workspaceId      String
  stripeInvoiceId  String    @unique
  invoiceNumber    String?
  issuedAt         DateTime
  amount           Int
  vatAmount        Int?
  currency         String    @default("eur")
  pdfUrl           String?
  hostedUrl        String?
  emailSentAt      DateTime?
  createdAt        DateTime  @default(now())
  // GoBD § 147: denormalized issuer identity (frozen at invoice time)
  issuerName       String?
  issuerVatId      String?
  issuerAddress    String?
  // GoBD § 147: denormalized recipient identity (frozen at invoice time)
  recipientName    String?
  recipientVatId   String?
  recipientAddress String?
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/// Tracks metered usage per workspace for subscription guardrails.
/// Prevents tier-creep by enforcing hard limits on user slots,
/// PDF generation quotas, and storage consumption.
model WorkspaceUsage {
  id                      String    @id @default(cuid())
  /// Max user slots granted by the current plan (e.g. 10 for Basic)
  userSlotsTotal          Int       @default(10)
  /// Number of PDFs generated in the current billing period
  pdfsGeneratedThisMonth  Int       @default(0)
  /// Maximum PDFs allowed per billing period (Basic=50, Professional=500, Enterprise=unlimited)
  pdfsMonthlyLimit        Int       @default(50)
  /// When the PDF counter was last reset (beginning of billing period)
  pdfsResetAt             DateTime  @default(now())
  /// Current signature/file storage consumption in bytes
  storageBytesUsed        BigInt    @default(0)
  /// Maximum storage allowed in bytes (Basic=500MB, Professional=5GB, Enterprise=unlimited)
  storageBytesLimit       BigInt    @default(524288000) // 500 MB
  /// Tickets created in the current billing period (counts against add-on tier quota)
  ticketsCreatedThisMonth Int       @default(0)
  /// Maximum tickets per month from add-on (0 = no add-on, Starter=200, Growth=500, Business=1000)
  ticketsMonthlyLimit     Int       @default(0)
  /// Ticket attachment storage consumption in bytes (separate from main storageBytesUsed)
  ticketStorageBytesUsed  BigInt    @default(0)
  /// Max ticket storage from add-on (0 = no add-on, Starter=5GB, Growth=15GB, Business=40GB)
  ticketStorageBytesLimit BigInt    @default(0)
  /// When the ticket counters were last reset (beginning of add-on billing period)
  ticketsResetAt          DateTime  @default(now())
  /// Transactional emails sent this billing period (PIN assignments, notifications)
  emailsSentThisMonth     Int       @default(0)
  /// Maximum emails allowed per billing period (Basic=100, Professional=500, Enterprise=unlimited=-1)
  emailsMonthlyLimit      Int       @default(100)
  /// When the email counter was last reset (beginning of billing period)
  emailsResetAt           DateTime  @default(now())
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  workspaceId             String    @unique
  workspace               Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Employee {
  id                String               @id @default(cuid())
  firstName         String
  lastName          String
  email             String?
  phone             String?
  position          String?
  hourlyRate        Float?
  weeklyHours       Float?
  workDaysPerWeek   Float                @default(5)
  contractType      ContractType         @default(VOLLZEIT)
  flexibleWork      Boolean              @default(false)
  color             String?
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?
  workspaceId       String
  workspace         Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId            String?              @unique
  user              User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  departmentId      String?
  department        Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  shifts            Shift[]
  timeEntries       TimeEntry[]
  absenceRequests   AbsenceRequest[]
  availabilities    Availability[]
  swapsRequested    ShiftSwapRequest[]   @relation("SwapRequester")
  swapsOffered      ShiftSwapRequest[]   @relation("SwapTarget")
  changeRequests    ShiftChangeRequest[]
  timeAccount       TimeAccount?
  vacationBalances  VacationBalance[]
  employeeSkills    EmployeeSkill[]
  projectMembers    ProjectMember[]
  autoFillsVacated  AutoFillLog[]        @relation("AutoFillVacated")
  autoFillsAssigned AutoFillLog[]        @relation("AutoFillAssigned")
  serviceVisits     ServiceVisit[]
  sosNotifications  SosNotification[]
  sosFilled         SosRequest[]         @relation("SosFilledBy")
  locationId        String?
  location          Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  pinHash           String?
  pinEmailFailed    Boolean              @default(false)

  @@unique([email, workspaceId])
  @@unique([workspaceId, pinHash])
  @@index([locationId])
  @@index([workspaceId])
}

model Location {
  id                    String                  @id @default(cuid())
  name                  String
  address               String?
  /// 2-letter Bundesland code (BE, BY, NW, …). Used by the holiday-aware
  /// vacation calculator. Falls back to Workspace.bundesland when null.
  bundesland            String?
  createdAt             DateTime                @default(now())
  workspaceId           String
  workspace             Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  shifts                Shift[]
  timeEntries           TimeEntry[]
  departments           Department[]
  shiftTemplates        ShiftTemplate[]
  staffingRequirements  StaffingRequirement[]
  autoScheduleRuns      AutoScheduleRun[]
  serviceVisits         ServiceVisit[]
  employees             Employee[]
  requiredSkills        LocationRequiredSkill[]
}

model Department {
  id                   String                @id @default(cuid())
  name                 String
  color                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  locationId           String?
  location             Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  workspaceId          String
  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  employees            Employee[]
  staffingRequirements StaffingRequirement[]

  @@index([workspaceId])
}

model Skill {
  id                    String                  @id @default(cuid())
  name                  String
  category              String?
  createdAt             DateTime                @default(now())
  workspaceId           String
  workspace             Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  employeeSkills        EmployeeSkill[]
  staffingRequirements  StaffingRequirement[]
  locationRequirements  LocationRequiredSkill[]

  @@unique([name, workspaceId])
  @@index([workspaceId])
}

model LocationRequiredSkill {
  id         String   @id @default(cuid())
  locationId String
  skillId    String
  createdAt  DateTime @default(now())
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([locationId, skillId])
  @@index([locationId])
  @@index([skillId])
}

model EmployeeSkill {
  id         String    @id @default(cuid())
  expiresAt  DateTime? @db.Date
  /// §34a / Sachkunde: the actual certificate identity, not just a label.
  certificateNumber String?
  issuingAuthority  String?
  issuedAt          DateTime? @db.Date
  /// Public URL of the uploaded certificate scan (Supabase Storage).
  documentUrl       String?
  documentName      String?
  createdAt  DateTime  @default(now())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([employeeId, skillId])
}

model ShiftTemplate {
  id          String    @id @default(cuid())
  name        String
  startTime   String
  endTime     String
  color       String?
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Shift {
  id               String               @id @default(cuid())
  date             DateTime             @db.Date
  startTime        String
  endTime          String
  notes            String?
  /// Planned break in minutes (ArbZG §4). Enforced as a hard block on save.
  breakMinutes     Int                  @default(0)
  status           ShiftStatus          @default(SCHEDULED)
  isNightShift     Boolean              @default(false)
  isHolidayShift   Boolean              @default(false)
  isSundayShift    Boolean              @default(false)
  surchargePercent Float                @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
  employeeId       String?
  // SET NULL: employee deletion unassigns shifts (schedule data preserved for audit trail)
  employee         Employee?            @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  locationId       String?
  location         Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  workspaceId      String
  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  swapsFrom        ShiftSwapRequest[]   @relation("SwapFromShift")
  swapsTo          ShiftSwapRequest[]   @relation("SwapToShift")
  changeRequests   ShiftChangeRequest[]
  autoFillLogs     AutoFillLog[]
  sosRequests      SosRequest[]

  @@index([workspaceId, date])
  @@index([employeeId, date])
  @@index([workspaceId, employeeId])
}

enum ShiftStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  OPEN
}

model PublicHoliday {
  id         String   @id @default(cuid())
  name       String
  date       DateTime @db.Date
  bundesland String
  isNational Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([date, bundesland])
  @@index([date])
  @@index([bundesland])
}

model VacationBalance {
  id               String    @id @default(cuid())
  year             Int
  totalEntitlement Float     @default(20)
  carryOver        Float     @default(0)
  used             Float     @default(0)
  planned          Float     @default(0)
  remaining        Float     @default(20)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  version          Int       @default(0)

  @@unique([employeeId, year])
  @@index([workspaceId])
}

enum TimeEntryStatus {
  ENTWURF
  EINGEREICHT
  KORREKTUR
  ZURUECKGEWIESEN
  GEPRUEFT
  BESTAETIGT
}

model TimeEntry {
  id           String           @id @default(cuid())
  date         DateTime         @db.Date
  startTime    String
  endTime      String
  breakStart   String?
  breakEnd     String?
  breakMinutes Int              @default(0)
  grossMinutes Int              @default(0)
  netMinutes   Int              @default(0)
  remarks      String?
  status       TimeEntryStatus  @default(ENTWURF)
  submittedAt  DateTime?
  confirmedAt  DateTime?
  confirmedBy  String?
  clockInAt    DateTime?
  clockOutAt   DateTime?
  isLiveClock  Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  employeeId   String
  // RESTRICT: cannot delete employee with time records (ArbZG §16: 2yr working-time retention)
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  locationId   String?
  location     Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  shiftId      String?
  projectId    String?
