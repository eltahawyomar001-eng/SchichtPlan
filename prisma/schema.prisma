// ═══════════════════════════════════════════════════════════════
// E-SIGNATURE (SES — Simple Electronic Signature per eIDAS Art. 25)
// ═══════════════════════════════════════════════════════════════

model ESignature {
  id            String    @id @default(cuid())
  action        String // e.g. "absence.approve", "time-entry.confirm"
  entityType    String // e.g. "AbsenceRequest", "TimeEntry"
  entityId      String // ID of the signed entity
  signedBy      String // User ID who signed
  signerName    String // Full name at time of signing (denormalized)
  signerEmail   String // Email at time of signing (denormalized)
  signerRole    String // Role at time of signing
  signatureHash String // SHA-256 hash of action+entity+timestamp+signer
  ipAddress     String? // IP address of the signer
  userAgent     String? // Browser user-agent string
  statement     String    @db.Text // The consent statement the user agreed to
  signedAt      DateTime  @default(now())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, signedAt])
  @@index([entityType, entityId])
  @@index([signedBy])
}

// ═══════════════════════════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════════════════════════

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  ARCHIVE
  LOGIN
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entityType  String // e.g. "shift", "employee", "absence"
  entityId    String? // ID of the affected entity
  userId      String? // User who performed the action
  userEmail   String? // Denormalized for readability
  changes     String?     @db.Text // JSON diff of changed fields
  metadata    String?     @db.Text // Additional context (IP, user-agent, etc.)
  createdAt   DateTime    @default(now())
  workspaceId String
  // RESTRICT: audit records must survive workspace deletion (HGB §257 / AO §147 / GoBD — 10yr retention)
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

