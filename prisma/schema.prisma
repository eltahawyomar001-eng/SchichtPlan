// ═══════════════════════════════════════════════════════════════
// AUTO-FILL & RECOVERY ENGINE
// ═══════════════════════════════════════════════════════════════

enum AutoFillStatus {
  PENDING // Searching for replacement
  ASSIGNED // Replacement found and assigned
  FAILED // No eligible candidate found
  DECLINED // Assigned employee declined
}

enum AlertSeverity {
  URGENT
  WARNING
  INFO
}

/// Log of every auto-fill attempt (successful or not).
/// Provides full audit trail for compliance & labour-law documentation.
model AutoFillLog {
  id                   String         @id @default(cuid())
  status               AutoFillStatus @default(PENDING)
  /// The shift that needs coverage
  shiftId              String
  shift                Shift          @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  /// Employee whose absence / swap vacated the shift
  vacatedByEmployeeId  String?
  vacatedByEmployee    Employee?      @relation("AutoFillVacated", fields: [vacatedByEmployeeId], references: [id], onDelete: SetNull)
  /// Employee who was auto-assigned as replacement
  assignedToEmployeeId String?
  assignedToEmployee   Employee?      @relation("AutoFillAssigned", fields: [assignedToEmployeeId], references: [id], onDelete: SetNull)
  /// Human-readable reason ("Absence approved for Max Müller")
  reason               String
  /// JSON array of compliance checks performed
  complianceChecks     Json           @default("[]")
  /// True when shift is < 4 days away (§ 12 TzBfG notice period)
  isEmergency          Boolean        @default(false)
  /// How many eligible candidates were evaluated
  candidatesEvaluated  Int            @default(0)
  /// Why no one was available (when status = FAILED)
  failureReason        String?
  createdAt            DateTime       @default(now())
  workspaceId          String
  workspace            Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([shiftId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

/// Urgent alerts surfaced to managers when automated recovery fails
/// or requires human intervention.
model ManagerAlert {
  id             String        @id @default(cuid())
  type           String // e.g. "NO_REPLACEMENT", "EMERGENCY_SHIFT", "COMPLIANCE_RISK"
  title          String
  message        String
  severity       AlertSeverity @default(WARNING)
  acknowledged   Boolean       @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String? // userId who ack'd
  /// Optional link to the relevant resource
  link           String?
  metadata       Json? // extra context (shiftId, employeeId, etc.)
  createdAt      DateTime      @default(now())
  workspaceId    String
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([severity])
  @@index([acknowledged])
  @@index([createdAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════
// DIGITALER LEISTUNGSNACHWEIS (Service Visit Proof System)
// ═══════════════════════════════════════════════════════════════

enum VisitStatus {
  GEPLANT // Scheduled, not yet started
  EINGECHECKT // Employee checked in at location
  ABGESCHLOSSEN // Visit completed with signature
  STORNIERT // Cancelled
}

enum ServiceReportStatus {
  ENTWURF // Draft — visits still open
  ERSTELLT // Generated — PDF created
  VERSENDET // Sent to client
}

/// A single service visit to a client location (e.g. cleaning Filiale #42).
/// Captures full audit trail: timestamps, signature.
model ServiceVisit {
  id             String                 @id @default(cuid())
  status         VisitStatus            @default(GEPLANT)
  scheduledDate  DateTime               @db.Date
  /// Check-in timestamp
  checkInAt      DateTime?
  /// Check-out timestamp
  checkOutAt     DateTime?
  /// Notes from the employee
  notes          String?                @db.Text
  /// Signature collected at this visit
  signature      VisitSignature?
  /// Revisionssicher audit trail
  visitAuditLogs ServiceVisitAuditLog[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  /// Relations
  employeeId     String
  employee       Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  locationId     String
  location       Location               @relation(fields: [locationId], references: [id], onDelete: Cascade)
  workspaceId    String
  workspace      Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reportId       String?
  report         ServiceReport?         @relation(fields: [reportId], references: [id], onDelete: SetNull)
  deletedAt      DateTime?

  @@index([workspaceId, scheduledDate])
  @@index([employeeId, scheduledDate])
  @@index([locationId])
  @@index([status])
  @@index([reportId])
}

/// Digital signature captured on-device from the site manager.
/// Cryptographically paired with timestamp via signatureHash.
model VisitSignature {
  id            String       @id @default(cuid())
  /// Base64-encoded PNG of the drawn signature
  signatureData String       @db.Text
  /// SHA-256 hash binding: visitId + signerName + timestamp
  signatureHash String
  /// Identity of the person who signed (e.g. Filialleiter name)
  signerName    String
  signerRole    String? // e.g. "Filialleiter", "Objektleiter"
  signedAt      DateTime     @default(now())
  /// 1:1 relation to the visit
  visitId       String       @unique
  visit         ServiceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

/// Consolidated proof-of-service report (Sammel-PDF).
/// Groups multiple visits for a client/period into one document.
model ServiceReport {
  id              String              @id @default(cuid())
  title           String
  status          ServiceReportStatus @default(ENTWURF)
  periodStart     DateTime            @db.Date
  periodEnd       DateTime            @db.Date
  /// URL to the generated PDF (stored in object storage)
  pdfUrl          String?             @db.Text
  generatedAt     DateTime?
  totalVisits     Int                 @default(0)
  completedVisits Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  workspaceId     String
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  visits          ServiceVisit[]

  @@index([workspaceId])
  @@index([status])
  @@index([periodStart, periodEnd])
}

/// Audit event types for service visit lifecycle tracking
enum VisitAuditEventType {
  CHECK_IN
  CHECK_OUT
  SIGNATURE_CAPTURED
  VISIT_CREATED
  VISIT_CANCELLED
  OFFLINE_SYNC
}

/// Revisionssicher (tamper-evident) audit log for every service visit event.
/// Each record bundles: what happened, who did it, when (server clock),
/// which device, plus a SHA-256 checksum for integrity verification.
/// This is the financial audit trail for Leistungsnachweis billing.
model ServiceVisitAuditLog {
  id              String              @id @default(cuid())
  eventType       VisitAuditEventType
  /// Server-authoritative timestamp (NOT device clock)
  serverTimestamp DateTime            @default(now())
  /// Client-reported timestamp (for drift detection)
  clientTimestamp DateTime?
  /// Device fingerprint
  deviceId        String? // navigator.userAgent hash or generated UUID
  userAgent       String?             @db.Text
  /// Signature data (only for SIGNATURE_CAPTURED events)
  signatureData   String?             @db.Text // base64 PNG
  /// SHA-256 checksum: eventType|visitId|serverTimestamp|deviceId
  /// Used to verify record has not been tampered with
  checksum        String
  /// Additional event-specific metadata (JSON)
  metadata        String?             @db.Text
  /// Whether this record was created from an offline sync
  offlineSync     Boolean             @default(false)
  /// Relations
  visitId         String
  visit           ServiceVisit        @relation(fields: [visitId], references: [id], onDelete: Cascade)
  userId          String?
  workspaceId     String

  @@index([visitId, serverTimestamp])
  @@index([workspaceId, serverTimestamp])
  @@index([eventType])
  @@index([offlineSync])
}

// ── iCal Feed Token ──────────────────────────────────────────────
/// Per-user token for subscribing to the iCal shift feed from
/// external calendar apps (Google Calendar, Apple Calendar, etc.)
/// that cannot use session cookies.
model ICalToken {
  id          String    @id @default(cuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  label       String?   @db.VarChar(100) // e.g. "Google Calendar"
  lastUsedAt  DateTime?
  rotatedAt   DateTime? // Last time the token was automatically rotated
  expiresAt   DateTime? // Hard expiry — requests after this date are rejected
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

// ═══════════════════════════════════════════════════════════════
// TICKETING SYSTEM
// ═══════════════════════════════════════════════════════════════

enum TicketCategory {
  SCHICHTPLAN
  ZEITERFASSUNG
  LOHNABRECHNUNG
  TECHNIK
  HR
  QUALITAETSMANGEL
  FEHLENDE_LEISTUNG
  SONSTIGES
}

enum TicketPriority {
  NIEDRIG
  MITTEL
  HOCH
  DRINGEND
}

enum TicketStatus {
  OFFEN
  IN_BEARBEITUNG
  GESCHLOSSEN
}

enum TicketType {
  INTERN
  EXTERN
}

enum TicketEventType {
  ERSTELLT
  ANGESEHEN
  STATUS_GEAENDERT
  ZUGEWIESEN
  KOMMENTAR
  GESCHLOSSEN
  ANGEHANGT
  GELOESCHT
  WIEDERHERGESTELLT
}

model Ticket {
  id                    String             @id @default(cuid())
  ticketNumber          String /// Human-readable e.g. TK-2025-0042 (unique per workspace)
  ticketType            TicketType         @default(INTERN)
  subject               String             @db.VarChar(200)
  description           String             @db.Text
  category              TicketCategory
  /// Per-workspace custom category. New tickets reference this; the
  /// enum field above stays populated as a legacy compatibility shim.
  categoryDefId         String?
  categoryDef           TicketCategoryDef? @relation(fields: [categoryDefId], references: [id], onDelete: SetNull)
  priority              TicketPriority     @default(MITTEL)
  status                TicketStatus       @default(OFFEN)
  location              String?            @db.VarChar(200) /// Free-text location (NOT GPS)
  /// Optional sub-object / specific address within the location
  /// (e.g. building wing, apartment number, customer site).
  objectAddress         String?            @db.VarChar(300)
  externalSubmitterName String?            @db.VarChar(200)
  externalToken         String?            @unique /// UUID token for external access link
  createdById           String? /// Null for external tickets
  createdBy             User?              @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignedToId          String?
  assignedTo            User?              @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  workspaceId           String
  workspace             Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  firstViewedAt         DateTime? /// When a processor first opened the ticket
  firstViewedById       String? /// Who first viewed the ticket
  firstResponseAt       DateTime? /// When first non-reporter responded
  resolvedAt            DateTime? /// When ticket was resolved/closed
  slaBreached           Boolean            @default(false) /// Whether SLA was breached
  closedAt              DateTime?
  /// Soft-delete (Papierkorb). Null = active, non-null = trashed. Hard
  /// purge is a separate explicit action that also walks blob storage.
  deletedAt             DateTime?
  /// Audit: who moved this ticket into the trash bin.
  deletedById           String?
  deletedBy             User?              @relation("TicketTrasher", fields: [deletedById], references: [id], onDelete: SetNull)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  comments              TicketComment[]
  events                TicketEvent[]
  attachments           TicketAttachment[]

  @@unique([workspaceId, ticketNumber])
  @@index([workspaceId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([externalToken])
  @@index([workspaceId, status])
  @@index([workspaceId, deletedAt])
  @@index([categoryDefId])
}

/// Persistent Stripe webhook idempotency log. Holds every event id we have
/// already processed so Stripe's 72-hour retry window cannot cause a
/// duplicate state transition. Cheaper and more durable than the previous
/// 5-minute Redis TTL.
model StripeEvent {
  id          String   @id /// Stripe event id (e.g. evt_1XYZ...)
  type        String   @db.VarChar(120)
  processedAt DateTime @default(now())
  payloadHash String?  @db.VarChar(64) /// optional sha256 of the raw body

  @@index([processedAt(sort: Desc)])
  @@index([type])
}

/// Per-workspace ticket category. Replaces the global TicketCategory enum
/// going forward; the enum is kept on Ticket as a legacy compatibility
/// shim for historical rows.
model TicketCategoryDef {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String          @db.VarChar(80) /// Display label
  slug        String          @db.VarChar(80) /// Stable kebab-case key
  color       String?         @db.VarChar(20) /// Optional hex/tailwind tag color
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  /// If seeded from a legacy enum value, store the enum name so we can
  /// resolve historical Ticket.category → TicketCategoryDef without a
  /// destructive migration.
  legacyEnum  TicketCategory?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tickets     Ticket[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive, sortOrder])
}

model TicketComment {
  id          String             @id @default(cuid())
  content     String             @db.Text
  isInternal  Boolean            @default(false) /// Only visible to management
  ticketId    String
  ticket      Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String? /// Null for external commenters
  author      User?              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorName  String?            @db.VarChar(200) /// Display name for external comments
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  attachments TicketAttachment[]

  @@index([ticketId])
  @@index([authorId])
}

model TicketEvent {
  id        String          @id @default(cuid())
  ticketId  String
  ticket    Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  eventType TicketEventType
  actorId   String? /// Null for system or external events
  actorName String?         @db.VarChar(200) /// Display name
  oldValue  String?         @db.VarChar(500)
  newValue  String?         @db.VarChar(500)
  metadata  String?         @db.Text /// JSON for extra context
  createdAt DateTime        @default(now())

  @@index([ticketId])
  @@index([ticketId, createdAt])
}

/// Files attached to a ticket or to a specific comment.
/// Stored in Vercel Blob; row holds the public URL + metadata.
/// Storage usage tracked via WorkspaceUsage.ticketStorageBytesUsed.
model TicketAttachment {
  id           String         @id @default(cuid())
  ticketId     String
  ticket       Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  /// Optional: attachment belongs to a specific comment instead of the ticket itself.
  commentId    String?
  comment      TicketComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  fileName     String         @db.VarChar(500)
  fileUrl      String         @db.Text /// Vercel Blob public URL
  fileType     String         @db.VarChar(150) /// MIME type
  fileSize     BigInt /// bytes
  uploadedById String? /// Null for external (token-based) uploads
  uploadedBy   User?          @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  uploaderName String?        @db.VarChar(200) /// Display name for external uploads
  workspaceId  String
  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())

  @@index([ticketId])
  @@index([commentId])
  @@index([workspaceId])
  @@index([uploadedById])
}

/// GoBD § 147 — per-workspace monotonic invoice counter.
/// One row per workspace; incremented atomically inside a transaction so
/// numbers are continuous and gap-free even under concurrent webhook delivery.
model InvoiceSequence {
  workspaceId String    @id
  lastNumber  Int       @default(0)
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

/// Tracks active station tablet sessions so managers can revoke access
/// without waiting for the 30-day cookie to expire.
model StationSession {
  id             String    @id @default(cuid())
  workspaceId    String
  sessionKeyHash String    @unique /// SHA-256 of the raw station_key cookie value
  deviceName     String    @default("Unbekanntes Gerät")
  issuedAt       DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  revokedAt      DateTime?
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([sessionKeyHash])
}

/// Versioned snapshot of our company identity for GoBD-compliant invoicing.
/// Add a new row (with validFrom = today) whenever address or VAT-ID changes;
/// the webhook picks the row whose validFrom ≤ invoice date.
model IssuerProfile {
  id        String   @id @default(cuid())
  name      String
  vatId     String?
  address   String?
  validFrom DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([validFrom])
}

// ═══════════════════════════════════════════════════════════════
// SOS SHIFT FILL
// ═══════════════════════════════════════════════════════════════

enum SosStatus {
  OPEN
  FILLED
  CANCELLED
  EXPIRED
}

enum SosResponse {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

/// Emergency shift-coverage request. Triggered by a manager when a shift
/// needs urgent filling. Notifies ranked employees in tiers and resolves
/// once someone accepts.
model SosRequest {
  id               String            @id @default(cuid())
  workspaceId      String
  shiftId          String
  createdById      String?
  bonusAmount      Decimal?          @db.Decimal(10, 2)
  bonusCurrency    String            @default("EUR")
  bonusNote        String?
  status           SosStatus         @default(OPEN)
  expiresAt        DateTime
  filledById       String?
  filledAt         DateTime?
  escalationTier   Int               @default(1)
  nextEscalationAt DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  shift            Shift             @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  createdBy        User?             @relation("SosCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  filledBy         Employee?         @relation("SosFilledBy", fields: [filledById], references: [id], onDelete: SetNull)
  notifications    SosNotification[]
  events           SosEvent[]

  @@index([workspaceId])
  @@index([shiftId])
  @@index([status])
}

/// Per-employee notification record for an SosRequest, including their
/// response and a unique token for one-click email response links.
model SosNotification {
  id              String      @id @default(cuid())
  sosRequestId    String
  employeeId      String
  tier            Int         @default(1)
  notifiedAt      DateTime    @default(now())
  response        SosResponse @default(PENDING)
  respondedAt     DateTime?
  responseToken   String      @unique
  linkOpenedAt    DateTime?
  sosRequest      SosRequest  @relation(fields: [sosRequestId], references: [id], onDelete: Cascade)
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([sosRequestId, employeeId])
  @@index([sosRequestId])
  @@index([employeeId])
}

/// Chronological audit ledger for SOS lifecycle events.
/// Each row records who did what at what time across the entire
/// SOS dispatch flow — used to power the live control-room view.
enum SosEventType {
  CREATED
  RANKED
  TIER_NOTIFIED
  LINK_OPENED
  ACCEPTED
  DECLINED
  ESCALATED
  FILLED
  EXPIRED
  CANCELLED
}

enum SosActorType {
  SYSTEM
  USER
  EMPLOYEE
}

model SosEvent {
  id           String       @id @default(cuid())
  sosRequestId String
  type         SosEventType
  actorType    SosActorType @default(SYSTEM)
  actorId      String?
  actorName    String?
  metadata     Json?
  createdAt    DateTime     @default(now())
  sosRequest   SosRequest   @relation(fields: [sosRequestId], references: [id], onDelete: Cascade)

  @@index([sosRequestId, createdAt])
}

/// Persistent queue for outbound transactional emails.
/// Allows a cron job to retry failed Resend deliveries without losing
/// critical emails (PIN, invitation, password reset) to transient failures.
model EmailJob {
  id           String    @id @default(cuid())
  to           String
  type         String
  category     String    @default("transactional")
  title        String
  message      String    @db.Text
  link         String?
  locale       String    @default("de")
  /// PENDING → attempted but not yet delivered; SENT → delivered; FAILED → gave up
  status       String    @default("PENDING")
  attempts     Int       @default(0)
  maxAttempts  Int       @default(5)
  /// When to attempt next (used for exponential back-off)
  nextRetryAt  DateTime?
  lastAttempt  DateTime?
  errorMessage String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, attempts])
  @@index([nextRetryAt])
  @@index([createdAt])
}
