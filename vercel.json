{
  "env": {
    "STRIPE_SIMULATION_MODE": "true"
  },
  "crons": [
    {
      "path": "/api/automations/generate-time-entries",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/automations/overtime-check",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/automations/payroll-lock",
      "schedule": "0 4 1 * *"
    },
    {
      "path": "/api/automations/break-reminder",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/admin/gps-cleanup",
      "schedule": "0 5 * * 0"
    }
  ]
}
